#!/usr/bin/env python3
"""ai — terminal command helper

Usage:
  ai <natural language request>
  ai --run <natural language request>     # executes the suggested command
  ai --explain <request>                  # get explanation + command

Config:
  ~/.config/ai/config.json

Providers:
  - openclaw: uses `openclaw agent` locally (recommended if your Gateway is configured with Claude Opus 4.6)
  - openai:   uses OpenAI Chat Completions API (requires OPENAI_API_KEY or configured env)
  - ollama:   uses local Ollama server (default http://localhost:11434)
"""

from __future__ import annotations

import argparse
import json
import os
import shlex
import subprocess
import sys
import textwrap
import urllib.request

DEFAULT_CONFIG_PATH = os.path.expanduser("~/.config/ai/config.json")

DEFAULT_CONFIG = {
    "provider": "openclaw",
    "openclaw": {
        "session_id": "ai-cli",
        "agent": None,
        "thinking": "low"
    },
    "openai": {
        "api_key_env": "OPENAI_API_KEY",
        "base_url": "https://api.openai.com/v1",
        "model": "gpt-5.2"
    },
    "ollama": {
        "base_url": "http://localhost:11434",
        "model": "qwen3:14b"
    },
    "behavior": {
        "shell": "bash",
        "max_tokens": 256,
        "temperature": 0.1
    }
}

SYSTEM_PROMPT_COMMAND_ONLY = textwrap.dedent(
    """\
    You translate natural language requests into a single best-effort Linux shell command.

    Output rules (critical):
    - Output ONLY the command (no markdown, no code fences, no commentary).
    - Prefer common GNU/Linux tools and safe read-only commands.
    - If the request is ambiguous, choose the safest reasonable interpretation.
    - Avoid destructive commands (rm, dd, mkfs, :(){:|:&};:, chmod -R, chown -R, etc.).
      If destruction is truly required, output: UNKNOWN
    - If you cannot produce a good command, output: UNKNOWN

    Examples:
    User: search running processes for python
    Output: ps -A | grep -i python

    User: find what is listening on port 8000
    Output: ss -ltnp | grep ':8000'
    """
).strip()

SYSTEM_PROMPT_EXPLAIN = textwrap.dedent(
    """\
    You help with Linux terminal commands.

    Output rules (critical):
    - First line: COMMAND: <one line shell command>
    - Then a short explanation (2-6 lines).
    - Prefer common GNU/Linux tools and safe read-only commands.
    - Avoid destructive commands; if required, say so and propose safe alternatives.
    """
).strip()


def eprint(*args: object) -> None:
    print(*args, file=sys.stderr)


def load_config(path: str) -> dict:
    if not os.path.exists(path):
        return json.loads(json.dumps(DEFAULT_CONFIG))
    with open(path, "r", encoding="utf-8") as f:
        return json.load(f)


def ensure_config_exists(path: str) -> None:
    if os.path.exists(path):
        return
    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "w", encoding="utf-8") as f:
        json.dump(DEFAULT_CONFIG, f, indent=2)
        f.write("\n")


def call_openclaw(cfg: dict, user_text: str, explain: bool) -> str:
    oc = cfg.get("openclaw", {})
    session_id = oc.get("session_id") or "ai-cli"
    agent = oc.get("agent")
    thinking = oc.get("thinking") or "low"

    system = SYSTEM_PROMPT_EXPLAIN if explain else SYSTEM_PROMPT_COMMAND_ONLY
    msg = f"{system}\n\nUser: {user_text}\n"

    cmd = ["openclaw", "agent", "--session-id", str(session_id), "--message", msg, "--thinking", str(thinking), "--json"]
    if agent:
        cmd.extend(["--agent", str(agent)])

    p = subprocess.run(cmd, capture_output=True, text=True)
    if p.returncode != 0:
        raise RuntimeError(p.stderr.strip() or f"openclaw agent failed ({p.returncode})")

    data = json.loads(p.stdout)
    payloads = (((data or {}).get("result") or {}).get("payloads") or [])
    text = (payloads[0].get("text") if payloads else "") or ""
    return text.strip()


def http_json(url: str, payload: dict, headers: dict | None = None) -> dict:
    body = json.dumps(payload).encode("utf-8")
    req = urllib.request.Request(url, data=body, method="POST")
    req.add_header("Content-Type", "application/json")
    if headers:
        for k, v in headers.items():
            req.add_header(k, v)
    with urllib.request.urlopen(req, timeout=60) as resp:
        raw = resp.read().decode("utf-8")
        return json.loads(raw)


def call_openai(cfg: dict, user_text: str, explain: bool) -> str:
    oa = cfg.get("openai", {})
    base_url = oa.get("base_url") or "https://api.openai.com/v1"
    model = oa.get("model") or "gpt-5.2"
    api_key_env = oa.get("api_key_env") or "OPENAI_API_KEY"
    api_key = os.environ.get(api_key_env)
    if not api_key:
        raise RuntimeError(f"Missing OpenAI API key in env var {api_key_env}")

    system = SYSTEM_PROMPT_EXPLAIN if explain else SYSTEM_PROMPT_COMMAND_ONLY

    payload = {
        "model": model,
        "messages": [
            {"role": "system", "content": system},
            {"role": "user", "content": user_text},
        ],
        "temperature": float((cfg.get("behavior", {}) or {}).get("temperature", 0.1)),
        "max_tokens": int((cfg.get("behavior", {}) or {}).get("max_tokens", 256)),
    }

    data = http_json(
        f"{base_url.rstrip('/')}/chat/completions",
        payload,
        headers={"Authorization": f"Bearer {api_key}"},
    )

    try:
        return (data["choices"][0]["message"]["content"] or "").strip()
    except Exception:
        raise RuntimeError(f"Unexpected OpenAI response: {json.dumps(data)[:4000]}")


def call_ollama(cfg: dict, user_text: str, explain: bool) -> str:
    ol = cfg.get("ollama", {})
    base_url = ol.get("base_url") or "http://localhost:11434"
    model = ol.get("model") or "qwen3:14b"

    system = SYSTEM_PROMPT_EXPLAIN if explain else SYSTEM_PROMPT_COMMAND_ONLY

    payload = {
        "model": model,
        "stream": False,
        "messages": [
            {"role": "system", "content": system},
            {"role": "user", "content": user_text},
        ],
        "options": {
            "temperature": float((cfg.get("behavior", {}) or {}).get("temperature", 0.1)),
            "num_predict": int((cfg.get("behavior", {}) or {}).get("max_tokens", 256)),
        },
    }

    data = http_json(f"{base_url.rstrip('/')}/api/chat", payload)
    msg = (data.get("message") or {}).get("content") or ""
    return msg.strip()


def normalize_command_output(text: str) -> str:
    t = (text or "").strip()
    # strip accidental code fences if the model disobeys
    if t.startswith("```"):
        t = t.strip("`")
        t = t.replace("bash\n", "").replace("sh\n", "")
        t = t.strip()
    return t.strip()


def main() -> int:
    parser = argparse.ArgumentParser(prog="ai", add_help=True)
    parser.add_argument("--config", default=DEFAULT_CONFIG_PATH)
    parser.add_argument("--provider", choices=["openclaw", "openai", "ollama"], help="Override provider")
    parser.add_argument("--run", action="store_true", help="Execute the suggested command")
    parser.add_argument("--explain", action="store_true", help="Return explanation + command")
    parser.add_argument("--init", action="store_true", help="Create default config and exit")
    parser.add_argument("query", nargs=argparse.REMAINDER, help="Your request")

    args = parser.parse_args()

    if args.init:
        ensure_config_exists(args.config)
        print(args.config)
        return 0

    if not args.query:
        eprint("Usage: ai <request>\nTry: ai --init")
        return 2

    cfg = load_config(args.config)
    provider = args.provider or cfg.get("provider") or "openclaw"

    user_text = " ".join(args.query).strip()
    if not user_text:
        eprint("Empty request")
        return 2

    try:
        if provider == "openclaw":
            out = call_openclaw(cfg, user_text, args.explain)
        elif provider == "openai":
            out = call_openai(cfg, user_text, args.explain)
        elif provider == "ollama":
            out = call_ollama(cfg, user_text, args.explain)
        else:
            raise RuntimeError(f"Unknown provider: {provider}")
    except Exception as e:
        eprint(f"ai: {e}")
        return 1

    out = normalize_command_output(out)

    if args.explain:
        # If model didn't follow format, just print what we got.
        print(out)
        return 0

    cmd = out.splitlines()[0].strip() if out else ""
    if cmd.upper() == "UNKNOWN" or cmd == "":
        eprint("UNKNOWN")
        return 3

    if args.run:
        # Run via user's shell for pipes/redirects.
        shell = ((cfg.get("behavior", {}) or {}).get("shell") or "bash")
        subprocess.run([shell, "-lc", cmd])
    else:
        print(cmd)

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
